<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Watch Movie</title>
    <link rel="stylesheet" href="css/main.css">
</head>
<body style="padding: 50px; text-align: center;">

    <h1 id="movieTitle">Inapakia...</h1>
    
    <div class="video-container">
        <iframe id="videoPlayer" width="80%" height="500" src="" frameborder="0" allowfullscreen></iframe>
    </div>

    <a href="index.html" style="color: #ff4500; display: block; margin-top: 20px;">Rudi Nyuma</a>

    <script>
        const params = new URLSearchParams(window.location.search);
        const movieId = params.get('id');

        fetch('movies.json')
            .then(res => res.json())
            .then(data => {
                const movie = data.find(m => m.id == movieId);
                if(movie) {
                    document.getElementById('movieTitle').innerText = movie.title;
                    document.getElementById('videoPlayer').src = movie.video_url;
                } else {
                    document.getElementById('movieTitle').innerText = "Muvi haipatikani!";
                }
            });
    </script>
</body>
</html>

